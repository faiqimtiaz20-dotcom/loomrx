# VITE_API_BASE_URL=https://api.example.com

# Circle: optional client-side shells (never put OAuth client secrets here)
# VITE_CIRCLE_PORTAL_URL=https://community.yourdomain.com
# VITE_CIRCLE_EMBED_URL=https://community.yourdomain.com/embed/community

# Display-only: show “live model” ribbon in AI UI when you wire a backend later
# VITE_OPENAI_ENABLED=true
